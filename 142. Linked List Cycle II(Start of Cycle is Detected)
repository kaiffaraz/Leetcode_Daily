/**
 * Definition for singly-linked list.
 * class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {
    public ListNode detectCycle(ListNode head) {
        int pos = 0;
        ListNode hare = head;
        ListNode turtle = hare;
        while(hare != null && hare.next != null){
            hare = hare.next.next;
            turtle = turtle.next;

            if(hare == turtle){
                ListNode ptr = head;
                while(ptr != turtle){
                    ptr = ptr.next;
                    turtle = turtle.next;
                }
                return ptr;
            }
        }
        return null;
    }
}
