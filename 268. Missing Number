class Solution {
    public int missingNumber(int[] nums) {
        int n = nums.length;
        Arrays.sort(nums);
        int ans = nums[0];
        if(nums[0] != 0){
            ans = 0;
        }
        for(int i = 0; i < n - 1; i++){
            if(nums[i]+1 != nums[i+1]){
                ans = nums[i] + 1;
            }
        }
        if(nums[n-1] != n){
                ans = n;
            }
        return ans;
    }
}
